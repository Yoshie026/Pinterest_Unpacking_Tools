{
  "name": "pinterest-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server exposing Pinterest boards & pins for mood-board analysis with Claude.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "pinterest-mcp": "./dist/server.js"
  },
  "scripts": {
    "auth": "tsx scripts/auth.ts",
    "dev": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "dxt": "node scripts/build-dxt.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.6",
    "express": "^4.21.1",
    "open": "^10.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
