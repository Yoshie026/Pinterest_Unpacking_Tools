# Pinterest OAuth app credentials
# Get these from your app at https://developers.pinterest.com/apps/
# Redirect URI on the app must be: http://localhost:3000/callback
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=

# Filled in automatically by `npm run auth`
PINTEREST_ACCESS_TOKEN=
PINTEREST_REFRESH_TOKEN=
PINTEREST_TOKEN_EXPIRES_AT=
